# Variáveis de Ambiente — Strike Zone

# ──────────────────────────────────────────────
# STRIPE — Pagamentos
# ──────────────────────────────────────────────

# Chave secreta da API Stripe (sk_test_... ou sk_live_...)
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_coloque_aqui

# Secret de validação do Webhook
# Obtenha em: https://dashboard.stripe.com/webhooks → seu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_coloque_aqui

# URL pública do site (sem barra no final)
# Usada para gerar os links de retorno do Stripe Checkout
PUBLIC_URL=https://strike-zone.onrender.com

# Price IDs dos produtos no Stripe Dashboard (opcional)
# Se deixar vazio, o sistema cria os preços dinamicamente (price_data)
# Obtenha em: https://dashboard.stripe.com/products → cada produto → Price ID
STRIPE_PRICE_STARTER=
STRIPE_PRICE_POPULAR=
STRIPE_PRICE_PRO=
STRIPE_PRICE_MEGA=
